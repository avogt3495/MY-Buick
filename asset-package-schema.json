{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycar.example/schemas/asset-package-v1.json",
  "title": "MY CAR Vehicle Asset Package",
  "type": "object",
  "required": [
    "packageId",
    "version",
    "tier",
    "label",
    "match",
    "delivery",
    "source",
    "features"
  ],
  "properties": {
    "packageId": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "channel": {
      "enum": [
        "stable",
        "beta",
        "development"
      ]
    },
    "tier": {
      "enum": [
        "exact",
        "generation",
        "body-template",
        "universal"
      ]
    },
    "label": {
      "type": "string"
    },
    "match": {
      "type": "object"
    },
    "geometryAccuracy": {
      "type": "string"
    },
    "scaleAccuracy": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "delivery": {
      "type": "object",
      "required": [
        "mode",
        "assetReady",
        "fallback"
      ],
      "properties": {
        "mode": {
          "enum": [
            "signed-glb",
            "public-glb",
            "procedural"
          ]
        },
        "assetReady": {
          "type": "boolean"
        },
        "asset": {
          "type": "string"
        },
        "fallback": {
          "type": "string"
        },
        "protected": {
          "type": "boolean"
        }
      }
    },
    "source": {
      "type": "object"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "releaseNotes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}